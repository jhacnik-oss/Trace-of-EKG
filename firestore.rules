rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Launch rules for the current public prototype.
    // Anonymous Auth must be enabled in Firebase Authentication.
    match /settings/main {
      allow read, write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
